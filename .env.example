# AEGIS Audio Editor / AI Video Dubber - Configuration
# Copy this file to backend/.env and adjust values as needed

# Server
PORT=8000
HOST=0.0.0.0

# Ollama API
OLLAMA_HOST=http://localhost:11434

# FFmpeg (default: uses bundled backend/bin/ffmpeg.exe, or system PATH)
# Set this only if you want to override the default
FFMPEG_PATH=

# Hugging Face cache directory (for model downloads)
HF_HOME=

# TTS Engine preference (voxcpm or vibevoice)
TTS_ENGINE_DEFAULT=voxcpm

# WhisperX model size (tiny, small, base, medium, large-v2, large-v3-turbo)
WHISPER_MODEL=large-v3-turbo
